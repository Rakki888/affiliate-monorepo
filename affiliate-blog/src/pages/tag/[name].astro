---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];

  return tags.map((tag) => ({
    params: { name: tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`${tag}の記事一覧`} description={`${tag}に関する記事の一覧です。`}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: `#${tag}` },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">#{tag}</h1>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post: any) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            publishedAt={post.data.publishedAt}
            slug={post.id}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500 dark:text-gray-400">このタグにはまだ記事がありません。</p>
    )}
  </div>
</BaseLayout>
