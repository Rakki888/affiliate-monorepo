---
import { getCollection } from 'astro:content';
import { SITE } from '../../config/site';
import { buildSearchIndex } from '../../lib/search';
import Navigation from './Navigation.astro';
import SearchBox from '../interactive/SearchBox.tsx';
import DarkModeToggle from '../interactive/DarkModeToggle.tsx';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const searchItems = buildSearchIndex(allPosts);
---

<header class="sticky top-0 z-40 w-full border-b border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900 dark:text-white hover:opacity-80 transition-opacity flex-shrink-0">
        <span class="text-2xl">📦</span>
        <span class="hidden sm:inline">{SITE.name}</span>
      </a>

      <div class="hidden lg:block flex-1 max-w-sm mx-4">
        <SearchBox items={searchItems} client:load />
      </div>

      <div class="flex items-center gap-2">
        <Navigation />
        <DarkModeToggle client:load />
      </div>
    </div>

    {/* モバイル検索バー */}
    <div class="lg:hidden pb-3">
      <SearchBox items={searchItems} client:load />
    </div>
  </div>
</header>
