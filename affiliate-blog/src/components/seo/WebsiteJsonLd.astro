---
import JsonLd from './JsonLd.astro';
import { SITE } from '../../config/site';
---

<JsonLd data={{
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}} />
