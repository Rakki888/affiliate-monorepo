---
import { getProductsByAsins } from '../../lib/amazon-api';
import { renderStars } from '../../lib/utils';
import type { Product, RankingItem } from '../../types/product';

interface Props {
  items: RankingItem[];
  title?: string;
}

const { items, title } = Astro.props;
const asins = items.map((i) => i.asin);
const products: Product[] = await getProductsByAsins(asins);

const rankColors: Record<number, string> = {
  1: 'bg-amber-400 text-white',
  2: 'bg-gray-300 text-gray-800',
  3: 'bg-amber-700 text-white',
};
---

<div class="not-prose my-8">
  {title && (
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">{title}</h3>
  )}

  <div class="space-y-6">
    {items.map((item, idx) => {
      const product = products.find((p) => p.asin === item.asin);
      if (!product) return null;
      const rank = idx + 1;

      return (
        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 overflow-hidden shadow-sm">
          {/* ランクヘッダー */}
          <div class="flex items-center gap-3 px-4 sm:px-6 py-3 bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700">
            <span class:list={[
              "flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold",
              rankColors[rank] ?? "bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-300",
            ]}>
              {rank}
            </span>
            <p class="font-medium text-gray-900 dark:text-white">{item.comment}</p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 p-4 sm:p-6">
            {/* 画像 */}
            <div class="flex-shrink-0 flex items-center justify-center sm:w-40">
              {product.imageUrl ? (
                <a href={product.url} target="_blank" rel="nofollow sponsored noopener">
                  <img src={product.imageUrl} alt={product.title} class="max-h-40 w-auto object-contain" loading="lazy" />
                </a>
              ) : (
                <div class="w-40 h-40 bg-gray-100 dark:bg-gray-700 flex items-center justify-center rounded-lg">
                  <span class="text-gray-400 text-sm">No Image</span>
                </div>
              )}
            </div>

            {/* 情報 */}
            <div class="flex-1 min-w-0">
              <a
                href={product.url}
                target="_blank"
                rel="nofollow sponsored noopener"
                class="text-base font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-2"
              >
                {product.title}
              </a>

              {product.brand && (
                <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">{product.brand}</p>
              )}

              <div class="mt-2 flex items-baseline gap-2 flex-wrap">
                {product.price && (
                  <span class="text-lg font-bold text-red-600 dark:text-red-400">{product.price.displayAmount}</span>
                )}
                {product.originalPrice && product.price && product.originalPrice.amount > product.price.amount && (
                  <span class="text-sm text-gray-400 line-through">{product.originalPrice.displayAmount}</span>
                )}
              </div>

              {product.rating && (
                <div class="mt-1 flex items-center gap-2 text-sm">
                  <span class="text-amber-500">{renderStars(product.rating.value)}</span>
                  <span class="text-gray-500 dark:text-gray-400">{product.rating.value.toFixed(1)} ({product.rating.count.toLocaleString()}件)</span>
                </div>
              )}

              {/* メリット/デメリット */}
              <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
                {item.pros && item.pros.length > 0 && (
                  <div>
                    {item.pros.map((pro) => (
                      <p class="flex items-start gap-1.5 text-sm text-gray-600 dark:text-gray-300">
                        <span class="text-green-500 flex-shrink-0">◎</span>
                        <span>{pro}</span>
                      </p>
                    ))}
                  </div>
                )}
                {item.cons && item.cons.length > 0 && (
                  <div>
                    {item.cons.map((con) => (
                      <p class="flex items-start gap-1.5 text-sm text-gray-600 dark:text-gray-300">
                        <span class="text-red-400 flex-shrink-0">△</span>
                        <span>{con}</span>
                      </p>
                    ))}
                  </div>
                )}
              </div>

              <div class="mt-4">
                <a
                  href={product.url}
                  target="_blank"
                  rel="nofollow sponsored noopener"
                  class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-amber-400 hover:bg-amber-500 text-gray-900 font-bold text-sm transition-colors shadow-sm"
                >
                  Amazonで見る
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <p class="mt-3 text-xs text-gray-400 text-center">※価格は取得時点のものです</p>
</div>
