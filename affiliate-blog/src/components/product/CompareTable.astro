---
import { getProductsByAsins } from '../../lib/amazon-api';
import { renderStars } from '../../lib/utils';
import type { Product } from '../../types/product';

interface Props {
  asins: string[];
  features?: string[];
  highlight?: string;
}

const { asins, features = [], highlight } = Astro.props;
const products: Product[] = await getProductsByAsins(asins);
---

<div class="not-prose my-6">
  {/* デスクトップ: テーブル */}
  <div class="hidden sm:block overflow-x-auto rounded-2xl border border-gray-200 dark:border-gray-700">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-700">
          <th class="p-4 text-left text-gray-500 dark:text-gray-400 font-medium"></th>
          {products.map((p) => (
            <th class:list={[
              "p-4 text-center min-w-[180px]",
              p.asin === highlight ? "bg-amber-50 dark:bg-amber-900/20" : "bg-white dark:bg-gray-800",
            ]}>
              {p.asin === highlight && (
                <span class="inline-block mb-2 px-2 py-0.5 rounded-full text-xs font-bold bg-amber-500 text-white">おすすめ</span>
              )}
              {p.imageUrl && (
                <a href={p.url} target="_blank" rel="nofollow sponsored noopener" class="block">
                  <img src={p.imageUrl} alt={p.title} class="mx-auto h-32 object-contain" loading="lazy" />
                </a>
              )}
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {/* 商品名 */}
        <tr class="border-b border-gray-100 dark:border-gray-700/50">
          <td class="p-4 font-medium text-gray-700 dark:text-gray-300">商品名</td>
          {products.map((p) => (
            <td class:list={[
              "p-4 text-center",
              p.asin === highlight ? "bg-amber-50/50 dark:bg-amber-900/10" : "",
            ]}>
              <a href={p.url} target="_blank" rel="nofollow sponsored noopener" class="font-medium text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 line-clamp-2">
                {p.title}
              </a>
            </td>
          ))}
        </tr>
        {/* 価格 */}
        <tr class="border-b border-gray-100 dark:border-gray-700/50">
          <td class="p-4 font-medium text-gray-700 dark:text-gray-300">価格</td>
          {products.map((p) => (
            <td class:list={[
              "p-4 text-center",
              p.asin === highlight ? "bg-amber-50/50 dark:bg-amber-900/10" : "",
            ]}>
              {p.price ? (
                <span class="font-bold text-red-600 dark:text-red-400">{p.price.displayAmount}</span>
              ) : (
                <span class="text-gray-400">-</span>
              )}
            </td>
          ))}
        </tr>
        {/* 評価 */}
        <tr class="border-b border-gray-100 dark:border-gray-700/50">
          <td class="p-4 font-medium text-gray-700 dark:text-gray-300">評価</td>
          {products.map((p) => (
            <td class:list={[
              "p-4 text-center",
              p.asin === highlight ? "bg-amber-50/50 dark:bg-amber-900/10" : "",
            ]}>
              {p.rating ? (
                <div>
                  <span class="text-amber-500 text-xs">{renderStars(p.rating.value)}</span>
                  <div class="text-gray-500 dark:text-gray-400 text-xs">{p.rating.value.toFixed(1)} ({p.rating.count}件)</div>
                </div>
              ) : (
                <span class="text-gray-400">-</span>
              )}
            </td>
          ))}
        </tr>
        {/* カスタム比較項目 */}
        {features.map((feat, idx) => (
          <tr class:list={[idx < features.length - 1 ? "border-b border-gray-100 dark:border-gray-700/50" : ""]}>
            <td class="p-4 font-medium text-gray-700 dark:text-gray-300">{feat}</td>
            {products.map((p) => {
              const matched = p.features.find((f) => f.includes(feat));
              return (
                <td class:list={[
                  "p-4 text-center text-xs text-gray-600 dark:text-gray-300",
                  p.asin === highlight ? "bg-amber-50/50 dark:bg-amber-900/10" : "",
                ]}>
                  {matched ? <span class="line-clamp-2">{matched}</span> : <span class="text-gray-400">-</span>}
                </td>
              );
            })}
          </tr>
        ))}
        {/* リンク */}
        <tr>
          <td class="p-4"></td>
          {products.map((p) => (
            <td class:list={[
              "p-4 text-center",
              p.asin === highlight ? "bg-amber-50/50 dark:bg-amber-900/10" : "",
            ]}>
              <a
                href={p.url}
                target="_blank"
                rel="nofollow sponsored noopener"
                class="inline-block px-4 py-2 rounded-lg bg-amber-400 hover:bg-amber-500 text-gray-900 font-bold text-xs transition-colors"
              >
                Amazonで見る
              </a>
            </td>
          ))}
        </tr>
      </tbody>
    </table>
  </div>

  {/* モバイル: カード形式フォールバック */}
  <div class="sm:hidden space-y-4">
    {products.map((p, idx) => (
      <div class:list={[
        "rounded-xl border p-4",
        p.asin === highlight
          ? "border-amber-300 dark:border-amber-600 bg-amber-50/50 dark:bg-amber-900/10"
          : "border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800",
      ]}>
        {p.asin === highlight && (
          <span class="inline-block mb-2 px-2 py-0.5 rounded-full text-xs font-bold bg-amber-500 text-white">おすすめ</span>
        )}
        <div class="flex gap-3">
          {p.imageUrl && (
            <img src={p.imageUrl} alt={p.title} class="w-20 h-20 object-contain flex-shrink-0" loading="lazy" />
          )}
          <div class="min-w-0">
            <a href={p.url} target="_blank" rel="nofollow sponsored noopener" class="font-medium text-sm text-gray-900 dark:text-white line-clamp-2">{p.title}</a>
            {p.price && <p class="mt-1 font-bold text-red-600 dark:text-red-400">{p.price.displayAmount}</p>}
            {p.rating && <p class="text-xs text-amber-500">{renderStars(p.rating.value)} {p.rating.value.toFixed(1)}</p>}
          </div>
        </div>
        <a
          href={p.url}
          target="_blank"
          rel="nofollow sponsored noopener"
          class="mt-3 block text-center px-4 py-2 rounded-lg bg-amber-400 hover:bg-amber-500 text-gray-900 font-bold text-xs transition-colors"
        >
          Amazonで見る
        </a>
      </div>
    ))}
  </div>

  <p class="mt-2 text-xs text-gray-400 text-center">※価格は取得時点のものです</p>
</div>
