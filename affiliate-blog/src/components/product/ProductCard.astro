---
import { getProductByAsin } from '../../lib/amazon-api';
import { renderStars } from '../../lib/utils';
import type { Product } from '../../types/product';

interface Props {
  asin: string;
  label?: string;
  description?: string;
}

const { asin, label, description } = Astro.props;
const product: Product = await getProductByAsin(asin);
---

<div class="not-prose my-6 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
  {label && (
    <div class="bg-amber-500 text-white text-xs font-bold px-4 py-1.5 text-center">
      {label}
    </div>
  )}

  <div class="flex flex-col sm:flex-row gap-4 p-4 sm:p-6">
    {/* 画像 */}
    <div class="flex-shrink-0 flex items-center justify-center sm:w-48">
      {product.imageUrl ? (
        <a href={product.url} target="_blank" rel="nofollow sponsored noopener">
          <img
            src={product.imageUrl}
            alt={product.title}
            class="max-h-48 w-auto object-contain"
            loading="lazy"
          />
        </a>
      ) : (
        <div class="w-48 h-48 bg-gray-100 dark:bg-gray-700 flex items-center justify-center rounded-lg">
          <span class="text-gray-400 text-sm">No Image</span>
        </div>
      )}
    </div>

    {/* 情報 */}
    <div class="flex-1 min-w-0">
      <a
        href={product.url}
        target="_blank"
        rel="nofollow sponsored noopener"
        class="text-lg font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-2"
      >
        {product.title}
      </a>

      {product.brand && (
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{product.brand}</p>
      )}

      {/* 価格 */}
      <div class="mt-2 flex items-baseline gap-2 flex-wrap">
        {product.price && (
          <span class="text-xl font-bold text-red-600 dark:text-red-400">
            {product.price.displayAmount}
          </span>
        )}
        {product.originalPrice && product.price && product.originalPrice.amount > product.price.amount && (
          <span class="text-sm text-gray-400 line-through">
            {product.originalPrice.displayAmount}
          </span>
        )}
      </div>

      {/* 評価 */}
      {product.rating && (
        <div class="mt-1 flex items-center gap-2 text-sm">
          <span class="text-amber-500">{renderStars(product.rating.value)}</span>
          <span class="text-gray-500 dark:text-gray-400">
            {product.rating.value.toFixed(1)} ({product.rating.count.toLocaleString()}件)
          </span>
        </div>
      )}

      {/* 特徴 */}
      {product.features.length > 0 && (
        <ul class="mt-3 space-y-1">
          {product.features.slice(0, 3).map((f) => (
            <li class="text-sm text-gray-600 dark:text-gray-300 flex gap-1.5">
              <span class="text-amber-500 flex-shrink-0">✓</span>
              <span class="line-clamp-1">{f}</span>
            </li>
          ))}
        </ul>
      )}

      {/* 補足説明 */}
      {description && (
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-300 bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3">
          {description}
        </p>
      )}

      {/* Amazon ボタン */}
      <div class="mt-4">
        <a
          href={product.url}
          target="_blank"
          rel="nofollow sponsored noopener"
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-amber-400 hover:bg-amber-500 text-gray-900 font-bold text-sm transition-colors shadow-sm"
        >
          Amazonで見る
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      <p class="mt-2 text-xs text-gray-400">※価格は取得時点のものです。最新の価格はAmazonでご確認ください。</p>
    </div>
  </div>
</div>
